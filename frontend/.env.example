# =============================================================================
# EXAMPLE ONLY — not real secrets. Commit as `.env.example`; do not commit `.env.local`.
#
# Golden path (avoids CSRF / cookie issues): use localhost everywhere in the browser
# and in backend `.env` — do not mix with another host.
#
# Setup for a friend:
#   1) Copy this file:  copy .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
#   2) Start Laravel API: php artisan serve --host=localhost --port=8000
#   3) Open the app at: http://localhost:3000   (npm run dev — Next binds :3000 by default)
#   4) Backend: copy backend/.env.example → backend/.env, then php artisan key:generate
# =============================================================================

# API base (must end with /api/v1 — same host style as the tab: localhost, not 127.0.0.1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

