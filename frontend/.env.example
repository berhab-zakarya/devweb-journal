# =============================================================================
# EXAMPLE ONLY — not real secrets. Commit as `.env.example`; do not commit `.env.local`.
#
# Golden path (avoids CSRF / cookie issues): use 127.0.0.1 everywhere in the browser
# and in backend `.env` — do not mix with `localhost`.
#
# Setup for a friend:
#   1) Copy this file:  copy .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
#   2) Start Laravel API: php artisan serve --host=127.0.0.1 --port=8000
#   3) Open the app at: http://127.0.0.1:3000   (npm run dev — Next binds :3000 by default)
#   4) Backend: copy backend/.env.example → backend/.env, then php artisan key:generate
# =============================================================================

# API base (must end with /api/v1 — same host style as the tab: 127.0.0.1, not localhost)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ---------------------------------------------------------------------------
# Prefer `localhost` in the browser instead? Then use BOTH lines below and
# change backend CORS + SANCTUM to localhost as in backend/.env.example notes.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
