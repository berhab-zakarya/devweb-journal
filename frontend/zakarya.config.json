{
  "version": "1",
  "api": {
    "baseUrl": "http://127.0.0.1:8000/api/v1",
    "timeout": 10000,
    "withAuth": true
  },
  "query": {
    "staleTime": 60000,
    "gcTime": 300000,
    "retry": 1,
    "refetchOnWindowFocus": false
  },
  "folders": {
    "srcDir": "src",
    "featuresDir": "features",
    "sharedDir": "shared"
  },
  "features": {
    "zustand": true,
    "zod": true,
    "reactHookForm": true,
    "i18n": false,
    "storybook": false,
    "playwright": false,
    "vitest": false
  },
  "plugins": []
}
